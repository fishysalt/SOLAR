{
    "servers": [
        {
            "name": "Douyin",
            "type": "stdio",
            "command": "uvx",
            "args": ["douyin-mcp-server"],
            "env": {
                "DASHSCOPE_API_KEY": "${DASHSCOPE_API_KEY}"
            },
            "enabled": true,
            "description": "抖音视频文案提取"
        },
        {
            "name": "ShuqiNovel",
            "type": "http",
            "baseUrl": "https://dashscope.aliyuncs.com/api/v1/mcps/market-cmapi00072981/mcp",
            "headers": {
                "Authorization": "Bearer ${DASHSCOPE_API_KEY}"
            },
            "enabled": true,
            "description": "书旗小说 - 小说查询、简介、封面图"
        },
        {
            "name": "BaiduWebSearch",
            "type": "http",
            "baseUrl": "https://qianfan.baidubce.com/v2/tools/web-search/mcp",
            "headers": {
                "Authorization": "Bearer ${APPBUILDER_API_KEY}"
            },
            "enabled": true,
            "description": "百度网页搜索（实时）"
}
    ]
}